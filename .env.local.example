# ==============================
# FlowCRM Environment Variables (v3 - Layer 3)
# ==============================

# --- Supabase (existing) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- n8n webhook secret (existing) ---
WEBHOOK_SECRET=my-super-secret-key-123

# --- Green API for WhatsApp (existing) ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
GREEN_API_URL=https://7107.api.greenapi.com

# --- Marketing site (existing) ---
MARKETING_SITE_URL=https://www.autoflowa.in/

# ==============================
# REQUIRED FOR LAYER 3 (AI personalization)
# ==============================

# --- GROQ API KEY (REQUIRED for AI personalization) ---
# Sign up free: https://console.groq.com
# Free tier: 30 req/min, 14,400 req/day — plenty for 12-100 msg/day
# Without this, system falls back to generic templates.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SENDER IDENTITY ---
# Tomar naam — message signature te jabe ("— Sami")
# Personal name use korle response rate beshi
SENDER_NAME=Sami

# --- DAILY OUTREACH LIMIT ---
# Daily koto msg generate hobe. Default 12.
# Increase carefully — tumi manually 12-15 e WhatsApp pathate paro din e
# (WhatsApp Business policy + tomar own time limit)
DAILY_OUTREACH_LIMIT=12
